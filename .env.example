# F1 Strategy Platform v4.0 - Environment Configuration
# Copy this file to .env and update with your production values

# ==========================================
# Database Configuration
# ==========================================
DB_USER=f1user
DB_PASSWORD=change_this_secure_password_in_production
DB_NAME=f1strategy

# Full database URL (for reference)
# DATABASE_URL=postgresql://f1user:password@postgres:5432/f1strategy

# ==========================================
# JWT Authentication
# ==========================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# CORS / Frontend
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://yourdomain.com

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# Application Settings
# ==========================================
APP_ENV=production
LOG_LEVEL=INFO
# DEBUG=false

# ==========================================
# Monitoring & Observability
# ==========================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_grafana_password
GRAFANA_ROOT_URL=http://localhost:3001

# Prometheus (internal)
PROMETHEUS_RETENTION=30d

# ==========================================
# ML Model Settings
# ==========================================
ML_MODEL_CACHE=/app/data/models
ENABLE_MODEL_CACHE=true

# ==========================================
# Rate Limiting
# ==========================================
# Default rate limits per endpoint type
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_HEAVY=10/minute
RATE_LIMIT_AUTH=5/minute

# ==========================================
# Security Headers
# ==========================================
# CSP Policy (adjust as needed for your deployment)
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"

# ==========================================
# SSL / HTTPS (Production)
# ==========================================
# SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
# ENABLE_HTTPS=true

# ==========================================
# Backup & Maintenance
# ==========================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=7

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ELITE_FEATURES=true
ENABLE_TELEMETRY=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true

# ==========================================
# Development Settings (don't use in production)
# ==========================================
# DEBUG=true
# RELOAD_ON_CHANGE=true
# SQL_ECHO=false
