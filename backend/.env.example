# =============================================================================
# F1 Strategy Platform — Backend Environment Variables
# Copy this file to .env and fill in real values for production deployment.
# NEVER commit the actual .env file to source control.
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — only override for local dev
PORT=8000

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
# Production: Railway PostgreSQL plugin URL (set automatically by Railway)
# Example: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/railway

# Development fallback (SQLite — do NOT use in production)
# DATABASE_URL=sqlite:///./f1_strategy.db

# ──────────────────────────────────────────────────────────────────────────────
# Authentication — JWT
# ──────────────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-this-in-production

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────────────────────────────────────
# Admin Account (created on first startup if no admin exists)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password-in-production
ADMIN_EMAIL=admin@f1strategy.com

# ──────────────────────────────────────────────────────────────────────────────
# CORS — Allowed Frontend Origins
# ──────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Example: https://f1-strategy.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────────────────────
# OpenF1 API
# ──────────────────────────────────────────────────────────────────────────────
# Public API — no key needed, but base URL can be overridden for mocking
OPENF1_BASE_URL=https://api.openf1.org/v1

# ──────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────────────────────────────────────
# Set to "false" to disable heavy ML/RL features if PyTorch unavailable
ENABLE_RL_ENGINE=true
ENABLE_ELITE_FEATURES=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_ENV=production
